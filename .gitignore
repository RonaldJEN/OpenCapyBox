# ========================================
# OpenCapyBox .gitignore
# ========================================

# ========================================
# 敏感文件和配置
# ========================================
.env
.env.local
.env.*.local
*.env
!.env.example
src/agent/config/config.yaml
src/agent/config/mcp.json
*.key
*.pem
*.p12
*.pfx
credentials.json
secrets.yaml

# ========================================
# 数据库和运行时数据
# ========================================
*.db
*.sqlite
*.sqlite3
data/
*.log
logs/

# ========================================
# Python
# ========================================
__pycache__/
*.py[cod]
*\.class
*.so
.Python
build/
dist/
develop-eggs/
downloads/
eggs/
.eggs/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
wheels/
share/python-wheels/
sdist/
var/
lib/
lib64/
pip-log.txt
pip-delete-this-directory.txt

# 虚拟环境
.venv
env/
venv/
ENV/

# 测试和覆盖率
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/
reports/

# 类型检查
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# 包管理锁文件
Pipfile.lock
poetry.lock
.pdm.toml
__pypackages__/

# Jupyter
.ipynb_checkpoints

# pyenv
.python-version

# 翻译
*.mo
*.pot

# ========================================
# Node.js / Frontend
# ========================================
node_modules/
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ========================================
# IDE 和编辑器
# ========================================

# VSCode（保留推荐扩展）
.vscode/*
!.vscode/extensions.json

# JetBrains
.idea/
*.iml
out/

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# ========================================
# 操作系统
# ========================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.TemporaryItems
.Trashes

# Windows
Thumbs.db
ehthumbs.db
*.stackdump
[Dd]esktop.ini
\.BIN/
*.lnk

# Linux
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ========================================
# Docker
# ========================================
.docker/
docker-compose.override.yml

# ========================================
# 临时文件和缓存
# ========================================
*.tmp
*.temp
*.bak
*.old
*.orig
*.cache

# ========================================
# 项目特定
# ========================================
test_output/
test_results/
*.backup
backup/
.claude

# 安全凭证
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
*.gpg
*.asc
*.crt
*.cer
*.der
