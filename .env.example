# OpenCapyBox 后端环境变量示例
# 标注说明：
# - [必填] 启动项目必须配置
# - [可选] 不配置则使用默认值
# - [按需必填] 启用对应功能时必须配置

# ============================================================
# [必填] 基础与认证
# ============================================================
APP_NAME="OpenCapyBox Backend"
DEBUG=true

# 登录账号（格式：username:password,username2:password2）
SIMPLE_AUTH_USERS="demo:demo123,test:test123"

# JWT 签名密钥（建议 32+ 随机字符串；不配置会有启动告警并使用派生密钥）
AUTH_SECRET_KEY="replace-with-a-random-secret-string"
AUTH_TOKEN_EXPIRE_MINUTES=720

# ============================================================
# [可选] API / 数据库 / CORS
# ============================================================
API_PREFIX="/api"
DATABASE_URL="sqlite:///./data/database/open_capy_box.db"
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ============================================================
# [按需必填] 模型能力（Model Registry）
# ============================================================
# 模型具体参数（provider / api_base / max_tokens 等）在 models.yaml 中配置。
# 此处仅填写 API Key 环境变量，供 models.yaml 的 ${ENV_VAR} 引用。
# 若不配置对应 Key，该模型会在启动时自动禁用。

# DashScope 统一密钥（Qwen / GLM / DeepSeek）
LLM_API_KEY="your-dashscope-api-key"

# MiniMax 模型需要（不用 MiniMax 可留空）
MINIMAX_API_KEY=""

# 兼容回退（仅当 models.yaml 不可用时生效）
LLM_API_BASE="https://dashscope.aliyuncs.com/compatible-mode/v1"
LLM_MODEL="qwen3-max-preview"
LLM_PROVIDER="openai"

# ============================================================
# [按需必填] OpenSandbox（代码执行 / 文件工具）
# ============================================================
SANDBOX_DOMAIN="your-sandbox-host:8080"
SANDBOX_API_KEY="your-sandbox-api-key"

# [可选] OpenSandbox 其他参数
SANDBOX_IMAGE="code-interpreter-agent:v1.1.0"
SANDBOX_PROTOCOL="http"
SANDBOX_USE_SERVER_PROXY=true
SANDBOX_TIMEOUT_MINUTES=10
SANDBOX_READY_TIMEOUT_SECONDS=120
SANDBOX_PERSISTENT_STORAGE_ENABLED=true
SANDBOX_HOST_STORAGE_ROOT="/tmp/sandbox"
SANDBOX_STORAGE_MOUNT_PATH="/home/user"

# ============================================================
# [可选] Agent / SSE / 时区
# ============================================================
AGENT_MAX_STEPS=100
AGENT_TOKEN_LIMIT=80000

# SSE_HEARTBEAT_INTERVAL: 心跳间隔（秒）
# SSE_SUBSCRIBE_TIMEOUT: 订阅超时时间（秒）
SSE_HEARTBEAT_INTERVAL=15
SSE_SUBSCRIBE_TIMEOUT=300

# UTC 偏移小时数（中国大陆常用 8）
TIMEZONE_OFFSET=8

# ============================================================
# [可选] 搜索与扩展模型
# ============================================================
# 博查搜索 AppCode（启用搜索工具时配置）
BOCHA_SEARCH_APPCODE=""
GEMINI_API_KEY=""

# ============================================================
# [可选] Embedding（不填则降级为关键词检索）
# ============================================================
EMBEDDING_API_KEY=""
EMBEDDING_API_BASE="https://api.openai.com/v1"
EMBEDDING_MODEL="text-embedding-3-small"
